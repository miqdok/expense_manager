<Page x:Class="ExpenseManager.WPF.Pages.WalletDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Wallet Details">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="← Назад" HorizontalAlignment="Left" Click="BackButton_Click" Padding="8,4" />

        <StackPanel Grid.Row="1" Margin="0,12,0,0">
            <TextBlock x:Name="WalletNameText" FontSize="22" FontWeight="Bold" />
            <TextBlock x:Name="WalletIdText" FontSize="12" Foreground="Gray" />
            <TextBlock x:Name="WalletCurrencyText" FontSize="14" Margin="0,4,0,0" />
            <TextBlock x:Name="WalletTotalText" FontSize="14" Margin="0,4,0,0" />
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Транзакції" FontSize="18" FontWeight="SemiBold" Margin="0,16,0,8" />

        <ListBox Grid.Row="3" x:Name="TransactionsListBox" SelectionChanged="TransactionsListBox_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <TextBlock Text="{Binding Date, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="130" />
                        <TextBlock Text="{Binding Category}" Width="100" />
                        <TextBlock Text="{Binding Amount, StringFormat='{}{0:N2}'}" Width="100" TextAlignment="Right" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
