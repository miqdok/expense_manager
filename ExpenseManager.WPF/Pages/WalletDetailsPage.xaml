<Page x:Class="ExpenseManager.WPF.Pages.WalletDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:ExpenseManager.WPF"
      Title="Wallet Details">
    <Page.Resources>
        <local:AmountColorConverter x:Key="AmountColorConverter" />
    </Page.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="← Назад" HorizontalAlignment="Left" Click="BackButton_Click" Padding="8,4" />

        <StackPanel Grid.Row="1" Margin="0,12,0,0">
            <TextBlock x:Name="WalletNameText" FontSize="22" FontWeight="Bold" />
            <TextBlock x:Name="WalletIdText" FontSize="12" Foreground="Gray" />
            <TextBlock x:Name="WalletCurrencyText" FontSize="14" Margin="0,4,0,0" />
            <TextBlock x:Name="WalletTotalText" FontSize="14" Margin="0,4,0,0" />
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Транзакції" FontSize="18" FontWeight="SemiBold" Margin="0,16,0,8" />

        <TextBlock Grid.Row="3" x:Name="EmptyTransactionsText" Text="Транзакцій немає" FontSize="14"
                   Foreground="Gray" Visibility="Collapsed" Margin="0,4,0,0" />

        <ListBox Grid.Row="3" x:Name="TransactionsListBox" SelectionChanged="TransactionsListBox_SelectionChanged"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Date, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" />
                        <TextBlock Grid.Column="1" Text="{Binding Category}" />
                        <TextBlock Grid.Column="2" Text="{Binding Description}" Foreground="Gray" TextTrimming="CharacterEllipsis" Margin="8,0" />
                        <TextBlock Grid.Column="3" Text="{Binding Amount, StringFormat='{}{0:N2}'}" TextAlignment="Right"
                                   Foreground="{Binding Amount, Converter={StaticResource AmountColorConverter}}" FontWeight="SemiBold" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
