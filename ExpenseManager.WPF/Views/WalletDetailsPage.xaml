<Page x:Class="ExpenseManager.WPF.Views.WalletDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:ExpenseManager.WPF"
      xmlns:vm="clr-namespace:ExpenseManager.WPF.ViewModels"
      d:DataContext="{d:DesignInstance Type=vm:WalletDetailsViewModel}"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Wallet Details">
    <Page.Resources>
        <local:AmountColorConverter x:Key="AmountColorConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <Button Content="← Назад" Command="{Binding GoBackCommand}" Padding="8,4" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Редагувати" Command="{Binding EditWalletCommand}" IsEnabled="{Binding IsNotLoading}" Padding="8,4" Margin="0,0,8,0" />
                <Button Content="Видалити" Command="{Binding DeleteWalletCommand}" IsEnabled="{Binding IsNotLoading}" Padding="8,4" />
            </StackPanel>
        </DockPanel>

        <ProgressBar Grid.Row="1" IsIndeterminate="True" Height="4" Margin="0,8,0,0"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Text="{Binding Wallet.Name}" FontSize="22" FontWeight="Bold" />
            <TextBlock Text="{Binding Wallet.Id, StringFormat='Id: {0}'}" FontSize="12" Foreground="Gray" />
            <TextBlock Text="{Binding Wallet.Currency, StringFormat='Валюта: {0}'}" FontSize="14" Margin="0,4,0,0" />
            <TextBlock Text="{Binding Wallet.TotalAmount, StringFormat='Баланс: {0:N2}'}" FontSize="14" Margin="0,4,0,0" />
        </StackPanel>

        <DockPanel Grid.Row="3" Margin="0,16,0,8">
            <TextBlock Text="Транзакції" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Content="+ Додати" Command="{Binding AddTransactionCommand}" IsEnabled="{Binding IsNotLoading}"
                    HorizontalAlignment="Right" Padding="12,6" FontSize="13" />
        </DockPanel>

        <Grid Grid.Row="4" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13" Padding="6" Margin="0,0,8,0" />
            <ComboBox Grid.Column="1" SelectedIndex="{Binding SelectedSortIndex}" FontSize="13" Padding="6" Width="150">
                <ComboBoxItem Content="За датою" />
                <ComboBoxItem Content="За сумою" />
                <ComboBoxItem Content="За категорією" />
            </ComboBox>
        </Grid>

        <TextBlock Grid.Row="6" Text="Транзакцій немає" FontSize="14" Foreground="Gray" Margin="0,4,0,0">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasTransactions}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <ListBox Grid.Row="6" ItemsSource="{Binding Transactions}" HorizontalContentAlignment="Stretch"
                 Visibility="{Binding HasTransactions, Converter={StaticResource BoolToVis}}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,2">
                        <Grid.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding DataContext.SelectTransactionCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                          CommandParameter="{Binding}" />
                        </Grid.InputBindings>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Date, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" />
                        <TextBlock Grid.Column="1" Text="{Binding Category}" />
                        <TextBlock Grid.Column="2" Text="{Binding Description}" Foreground="Gray" TextTrimming="CharacterEllipsis" Margin="8,0" />
                        <TextBlock Grid.Column="3" Text="{Binding Amount, StringFormat='{}{0:N2}'}" TextAlignment="Right"
                                   Foreground="{Binding Amount, Converter={StaticResource AmountColorConverter}}" FontWeight="SemiBold" />
                        <Button Grid.Column="4" Content="X" Padding="6,2" Margin="8,0,0,0"
                                Command="{Binding DataContext.DeleteTransactionCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
