<Page x:Class="ExpenseManager.WPF.Views.WalletDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:ExpenseManager.WPF"
      xmlns:vm="clr-namespace:ExpenseManager.WPF.ViewModels"
      d:DataContext="{d:DesignInstance Type=vm:WalletDetailsViewModel}"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Wallet Details">
    <Page.Resources>
        <local:AmountColorConverter x:Key="AmountColorConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="← Назад" HorizontalAlignment="Left"
                Command="{Binding GoBackCommand}" Padding="8,4" />

        <StackPanel Grid.Row="1" Margin="0,12,0,0">
            <TextBlock Text="{Binding Wallet.Name}" FontSize="22" FontWeight="Bold" />
            <TextBlock Text="{Binding Wallet.Id, StringFormat='Id: {0}'}" FontSize="12" Foreground="Gray" />
            <TextBlock Text="{Binding Wallet.Currency, StringFormat='Валюта: {0}'}" FontSize="14" Margin="0,4,0,0" />
            <TextBlock Text="{Binding Wallet.TotalAmount, StringFormat='Баланс: {0:N2}'}" FontSize="14" Margin="0,4,0,0" />
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Транзакції" FontSize="18" FontWeight="SemiBold" Margin="0,16,0,8" />

        <TextBlock Grid.Row="3" Text="Транзакцій немає" FontSize="14" Foreground="Gray" Margin="0,4,0,0">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasTransactions}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <ListBox Grid.Row="3" ItemsSource="{Binding Transactions}" HorizontalContentAlignment="Stretch"
                 Visibility="{Binding HasTransactions, Converter={StaticResource BoolToVis}}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,2">
                        <Grid.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding DataContext.SelectTransactionCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                          CommandParameter="{Binding}" />
                        </Grid.InputBindings>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Date, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" />
                        <TextBlock Grid.Column="1" Text="{Binding Category}" />
                        <TextBlock Grid.Column="2" Text="{Binding Description}" Foreground="Gray" TextTrimming="CharacterEllipsis" Margin="8,0" />
                        <TextBlock Grid.Column="3" Text="{Binding Amount, StringFormat='{}{0:N2}'}" TextAlignment="Right"
                                   Foreground="{Binding Amount, Converter={StaticResource AmountColorConverter}}" FontWeight="SemiBold" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
